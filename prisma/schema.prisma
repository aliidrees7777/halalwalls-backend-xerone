// HalalWalls — Postgres (Supabase) schema via Prisma.
// Translated from the original Mongoose models. Table names keep the hw_ prefix.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // transaction pooler (app runtime)
  directUrl = env("DIRECT_URL")   // session pooler (migrations)
}

enum Role {
  user
  admin
}

enum AuthProvider {
  local
  google
}

enum WallpaperStatus {
  active
  pending
  hidden
}

enum ContactStatus {
  new
  read
  resolved
}

model User {
  id                       String       @id @default(uuid()) @db.Uuid
  firstName                String
  lastName                 String       @default("")
  email                    String       @unique
  password                 String? // hashed; null for Google-only accounts
  role                     Role         @default(user)
  authProvider             AuthProvider @default(local)
  googleId                 String?
  avatar                   String?
  emailVerified            Boolean      @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  bio                      String       @default("")
  banner                   String?
  isPremium                Boolean      @default(false)
  // Stripe subscription state (monthly premium plan)
  stripeCustomerId         String?      @unique
  stripeSubscriptionId     String?
  subscriptionStatus       String? // active | trialing | past_due | canceled | ...
  subscriptionPlan         String? // e.g. "monthly"
  currentPeriodEnd         DateTime?
  passwordResetToken       String?
  passwordResetExpires     DateTime?
  sessionsValidFrom        DateTime?
  // Soft delete: the row + data stay; the account can't sign in until reactivated.
  isDeleted                Boolean      @default(false)
  deletedAt                DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  favorites        Favorite[]
  uploadedWallpapers Wallpaper[] @relation("UploadedBy")

  @@map("hw_users")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String   @default("")
  image       String?
  order       Int      @default(0)
  isPremium   Boolean  @default(false)
  isActive    Boolean  @default(true) // admin toggle: hidden from nav/upload when false
  count       Int      @default(0) // cached; live count computed in the API
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hw_categories")
}

model Wallpaper {
  id                  String          @id @default(uuid()) @db.Uuid
  title               String
  slug                String          @unique
  description         String          @default("")
  category            String? // primary display label (e.g. "Anime")
  categorySlug        String? // primary filter slug (e.g. "anime")
  /// Additional + primary labels (multi-category). Primary is also categories[0].
  categories          String[]        @default([])
  /// Additional + primary slugs (multi-category). Primary is also categorySlugs[0].
  categorySlugs       String[]        @default([])
  tags                String[]        @default([])
  image               String?
  originalUrl         String?
  thumbnailUrl        String?
  resolution          String          @default("") // native, e.g. "1920x1080"
  preferredResolution String          @default("")
  resolutions         String[]        @default([])
  sizeMB              Float           @default(0)
  width               Int?
  height              Int?
  author              String          @default("HalalWalls")
  isPremium           Boolean         @default(false)
  isLive              Boolean         @default(false)
  status              WallpaperStatus @default(active)
  downloadCount       Int             @default(0)
  views               Int             @default(0)
  favoritesCount      Int             @default(0)
  uploadedById        String?         @db.Uuid
  uploadedBy          User?           @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  favorites Favorite[]

  @@index([categorySlug, status])
  @@index([status, createdAt])
  @@index([status, downloadCount])
  @@index([resolution])
  @@map("hw_wallpapers")
}

// Join table for the user↔wallpaper many-to-many favorites
// (replaces the favorites array on the Mongo User).
model Favorite {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  wallpaperId String    @db.Uuid
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallpaper   Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@unique([userId, wallpaperId])
  @@index([userId])
  @@map("hw_favorites")
}

// Admin-managed roles + their permission grants (management layer). The API's
// runtime guard still uses User.role (user/admin); this drives the Roles &
// Permissions admin UI.
model AdminRole {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  key         String   @unique
  description String   @default("")
  permissions String[] @default([])
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hw_roles")
}

// Admin-managed tag metadata (description / active toggle). The actual tags on
// wallpapers live in Wallpaper.tags[]; the admin Tags page unions these rows
// with the tags users apply, so user-created tags surface automatically.
model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hw_tags")
}

// Admin-managed resolution catalog. Drives the public "browse by resolution"
// nav + the download-size options, and the admin Resolutions page. Usage
// (wallpapers/downloads) is derived from Wallpaper.resolution + DownloadEvent.
model Resolution {
  id          String   @id @default(uuid()) @db.Uuid
  label       String   @unique // display, e.g. "3840×2160"
  width       Int
  height      Int
  aspectRatio String   @default("")
  device      String   @default("desktop") // desktop | mobile
  fileSizeMB  Float    @default(0)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([width, height])
  @@map("hw_resolutions")
}

// One row per wallpaper download — the timestamped log behind the dashboard's
// "downloads per day" trend and date filters. Wallpaper.downloadCount stays as
// the cumulative counter; this table adds the time dimension. Stored as plain
// ids (no relations) so a deleted user/wallpaper never removes historical stats.
model DownloadEvent {
  id          String   @id @default(uuid()) @db.Uuid
  wallpaperId String   @db.Uuid
  userId      String?  @db.Uuid
  resolution  String?
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([wallpaperId])
  @@map("hw_download_events")
}

model Contact {
  id        String        @id @default(uuid()) @db.Uuid
  name      String?
  email     String?
  reason    String?
  message   String
  status    ContactStatus @default(new)
  createdAt DateTime      @default(now())

  @@map("hw_contacts")
}
