# ── Runtime ──
NODE_ENV=development
NODE_CONFIG_DIR=src/config
SUPPRESS_NO_CONFIG_WARNING=true

# ── Server ──
PORT=4000

# ── Database (MongoDB Atlas) ──
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/HalalWalls?retryWrites=true&w=majority

# ── JWT & Auth ──
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_MIN=60

# ── Frontend URL (used in email reset links) ──
APP_URL=http://localhost:9845

# ── Google OAuth (only CLIENT_ID is strictly required for sign-in) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# ── Email (EMAIL_PROVIDER = smtp | sendgrid) ──
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@halalwalls.com
EMAIL_FROM_NAME=HalalWalls

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_RESET_TEMPLATE_ID=

# ── Cloudflare R2 / S3 (wallpaper image storage; all 5 required to enable, else local /uploads) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=

# ── API Docs (optional; pins Swagger server dropdown) ──
SWAGGER_SERVER_URL=
